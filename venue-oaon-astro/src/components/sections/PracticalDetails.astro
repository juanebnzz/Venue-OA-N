---
const details = [
  {
    title: 'No Corkage Fee',
    desc:  'Bring your own wine, champagne, or cocktails. No corkage fees, ever.',
    svg: `<path d="M8 16C8 11.58 11.58 8 16 8C20.42 8 24 11.58 24 16" stroke="currentColor" stroke-width="0.75" stroke-linecap="round"/><path d="M4 24H28" stroke="currentColor" stroke-width="0.75" stroke-linecap="round"/><path d="M16 8V4" stroke="currentColor" stroke-width="0.75" stroke-linecap="round"/>`,
    extra: null,
  },
  {
    title: 'Self-Catering',
    desc:  'Bring your own caterer, order in, or cook yourself. Kitchen access on selected packages.',
    svg: `<rect x="6" y="10" width="20" height="16" rx="1" stroke="currentColor" stroke-width="0.75"/><path d="M10 10V8C10 6.9 10.9 6 12 6H20C21.1 6 22 6.9 22 8V10" stroke="currentColor" stroke-width="0.75"/><path d="M16 15V21M13 18H19" stroke="currentColor" stroke-width="0.75" stroke-linecap="round"/>`,
    extra: null,
  },
  {
    title: 'Secured Parking',
    desc:  'On-site secured parking for all guests. No stress on arrival day.',
    svg: `<rect x="5" y="12" width="22" height="14" rx="1" stroke="currentColor" stroke-width="0.75"/><path d="M10 12V9C10 7.9 12.69 7 16 7C19.31 7 22 7.9 22 9V12" stroke="currentColor" stroke-width="0.75"/><circle cx="16" cy="19" r="2" stroke="currentColor" stroke-width="0.75"/>`,
    extra: null,
  },
  {
    title: 'Two Time Slots',
    desc:  'Morning and afternoon sessions : your event always starts fresh.',
    svg: `<circle cx="16" cy="16" r="11" stroke="currentColor" stroke-width="0.75"/><path d="M16 10V16L20 18" stroke="currentColor" stroke-width="0.75" stroke-linecap="round"/>`,
    extra: 'slots',
  },
];
---

<section class="section section--linen">
  <div class="wrap">
    <div class="section-header reveal">
      <span class="label">Good to Know</span>
      <h2 class="section-title" style="margin-top:1rem;">The details that matter.</h2>
    </div>
    <div class="details-grid">
      {details.map(({ title, desc, svg, extra }, i) => (
        <div class={`detail-card reveal${i === 1 ? ' d1' : i === 2 ? ' d2' : i === 3 ? ' d3' : ''}`}>
          <svg class="detail-icon" viewBox="0 0 32 32" fill="none" aria-hidden="true" set:html={svg} />
          <h3 class="detail-title">{title}</h3>
          <p class="detail-desc">{desc}</p>
          {extra === 'slots' && (
            <div class="time-slots">
              <span class="time-slot">08:00 – 13:00</span>
              <span class="time-slot">14:00 – 19:00</span>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .details-grid { display: grid; gap: 1rem; grid-template-columns: 1fr; }
  @media (min-width: 640px)  { .details-grid { grid-template-columns: repeat(2,1fr); } }
  @media (min-width: 1024px) { .details-grid { grid-template-columns: repeat(4,1fr); } }

  .detail-card {
    background: #FFFFFF;
    border-radius: 8px;
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: box-shadow 0.2s;
  }
  .detail-card:hover { box-shadow: 0 4px 24px rgba(0,0,0,0.05); }
  .detail-icon  { color: #8B6448; width: 28px; height: 28px; }
  .detail-title { font-family: 'Tenor Sans', serif; font-size: 1rem; letter-spacing: 0.04em; }
  .detail-desc  { font-size: var(--text-sm); color: #8C8578; line-height: 1.65; }

  .time-slots { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 0.25rem; }
  .time-slot {
    font-size: var(--text-xs);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 2px;
    background: #F5F2EE;
    border: 0.5px solid #E0DDD8;
    color: #1A1A1A;
  }
  .section-title {
    font-family: 'Tenor Sans', serif;
    font-size: var(--text-h2);
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1.1;
    color: #1A1A1A;
  }
</style>
