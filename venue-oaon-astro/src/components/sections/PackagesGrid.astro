---
import PackageCard from '../ui/PackageCard.astro';
import Button from '../ui/Button.astro';
import packages from '../../content/packages.json';

interface Props {
  preview?: boolean;
}
const { preview = false } = Astro.props;
const displayPkgs = preview ? packages : packages;
---

{preview ? (
  <section class="section">
    <div class="wrap">
      <div class="section-header reveal" style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:1.5rem;">
        <div>
          <span class="label">Packages</span>
          <h2 class="section-title" style="margin-top:1rem;">Décor done for you.</h2>
        </div>
        <Button href="/packages" variant="outline">View All Packages</Button>
      </div>

      <div class="pkg-grid">
        {displayPkgs.map((pkg, i) => (
          <PackageCard
            {...pkg}
            class={`reveal${i === 1 ? ' d1' : i === 2 ? ' d2' : i === 3 ? ' d3' : ''}`}
          />
        ))}
      </div>

      <div class="pkgs-cta reveal">
        <p style="font-size:var(--text-sm);color:#8C8578;margin-bottom:1rem;">All packages offered through Oaón Events · Custom scopes always available</p>
        <Button href="/packages" variant="accent">Explore Packages</Button>
      </div>
    </div>
  </section>
) : (
  <section class="section section--linen">
    <div class="wrap">
      <div class="section-header reveal">
        <span class="label">Décor Packages</span>
        <h2 class="section-title" style="margin-top:1rem;">Four tiers. Every occasion.</h2>
      </div>
      <div class="pkg-grid">
        {displayPkgs.map((pkg, i) => (
          <PackageCard
            {...pkg}
            class={`reveal${i === 1 ? ' d1' : i === 2 ? ' d2' : i === 3 ? ' d3' : ''}`}
          />
        ))}
      </div>
    </div>
  </section>
)}

<style>
  .pkg-grid {
    display: grid;
    gap: 1px;
    background: #E0DDD8;
    border: 0.5px solid #E0DDD8;
    border-radius: 10px;
    overflow: hidden;
    grid-template-columns: 1fr;
  }
  @media (min-width: 640px)  { .pkg-grid { grid-template-columns: repeat(2,1fr); } }
  @media (min-width: 1024px) { .pkg-grid { grid-template-columns: repeat(4,1fr); } }

  .pkgs-cta { margin-top: 2rem; text-align: center; }
  .section-title {
    font-family: 'Tenor Sans', serif;
    font-size: var(--text-h2);
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1.1;
    color: #1A1A1A;
  }
</style>
