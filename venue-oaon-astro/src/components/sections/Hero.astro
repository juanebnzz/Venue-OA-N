---
import Button from "../ui/Button.astro";
---

<section class="hero">
  <div class="hero-bg" aria-hidden="true"></div>
  <span class="hero-tag" aria-hidden="true">Montana · Pretoria</span>

  <div class="hero-content">
    <div class="hero-eyebrow">
      <span class="label" style="color:white;">Intimate event space</span>
    </div>

    <h1 class="hero-h1">
      A space made<br />
      for your<br />
      moment.
    </h1>

    <div class="hero-bottom">
      <p class="hero-sub">
        Three suites for gatherings of 20–40 people. Baby showers, kitchen teas,
        bridal showers, birthdays.
      </p>

      <div class="hero-actions">
        <Button href="/contact" variant="accent">Begin the Inquiry</Button>
        <a href="#suites" class="hero-ghost-btn">Explore the Suites</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    overflow: hidden;
    padding-top: var(--nav-h);
    display: flex;
    align-items: flex-end;
    padding-bottom: 10vh;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background-image: url("/images/hero_bg_1.jpg");
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: 0;
    transform: scale(1.03);
  }

  /* Dual-axis overlay: left-column gradient for text legibility (WCAG 4.5:1)
     plus a bottom vignette for depth : image stays visible on the right. */
  .hero-bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        to right,
        rgba(0, 0, 0, 0.60) 0%,
        rgba(0, 0, 0, 0.42) 45%,
        rgba(0, 0, 0, 0.08) 75%,
        transparent 100%
      ),
      linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0.08) 0%,
        rgba(0, 0, 0, 0.22) 55%,
        rgba(0, 0, 0, 0.50) 100%
      );
  }

  .hero-tag {
    position: absolute;
    top: 88px;
    right: clamp(1.5rem, 3vw, 3rem);
    z-index: 2;
    writing-mode: vertical-rl;
    font-size: var(--text-xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 680px;
    padding-left: clamp(2rem, 8vw, 8rem);
  }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }

  .hero-eyebrow::before {
    content: "";
    display: block;
    width: 32px;
    height: 0.5px;
    background: #8c8578;
  }

  /* Editorial type scale : desktop H1 ≥ 4× body (1rem × 4 = 4rem min).
     8rem (128px) at full width keeps hierarchy dominant and tight. */
  .hero-h1 {
    font-family: "Tenor Sans", serif;
    font-size: clamp(3.5rem, 8vw, 6rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: 0.01em;
    color: #ffffff;
    text-shadow: 0 2px 24px rgba(0, 0, 0, 0.30);
    margin-bottom: clamp(2rem, 4vw, 3rem);
    max-width: 10ch;
  }

  .hero-bottom {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .hero-sub {
    font-size: var(--text-body);
    line-height: 1.75;
    color: rgba(255, 255, 255, 0.82);
    max-width: 420px;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* Ghost CTA : bordered 'ghost-light' style with a guaranteed 44×44px touch
     target, meeting WCAG 2.5.5 (AA) pointer target size requirements. */
  .hero-ghost-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
    font-family: 'Tenor Sans', serif;
    font-size: var(--text-xs);
    font-weight: 400;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #ffffff;
    border: 1px solid rgba(255, 255, 255, 0.55);
    border-radius: 2px;
    text-decoration: none;
    background: transparent;
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    transition: background 0.22s ease, border-color 0.22s ease, color 0.22s ease;
  }
  .hero-ghost-btn:hover,
  .hero-ghost-btn:focus-visible {
    background: rgba(255, 255, 255, 0.14);
    border-color: rgba(255, 255, 255, 0.85);
    outline: 2px solid rgba(255, 255, 255, 0.6);
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .hero-tag { display: none; }

    .hero {
      align-items: flex-end;
      padding-bottom: 0;
    }

    /* Full top-to-bottom fade on mobile — replaces the desktop left-to-right gradient */
    .hero-bg::after {
      background: linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0.18) 0%,
        rgba(0, 0, 0, 0.42) 45%,
        rgba(0, 0, 0, 0.72) 80%,
        rgba(0, 0, 0, 0.82) 100%
      );
    }

    .hero-content {
      width: 100%;
      max-width: 100%;
      padding: 2rem 1.5rem 3rem;
      text-align: center;
      background: rgba(10, 8, 6, 0.52);
      backdrop-filter: blur(14px) saturate(140%);
      -webkit-backdrop-filter: blur(14px) saturate(140%);
      border-top: 0.5px solid rgba(255, 255, 255, 0.12);
      border-radius: 4px 4px 0 0;
    }

    .hero-eyebrow {
      justify-content: center;
    }

    .hero-h1 {
      font-size: clamp(2.5rem, 10vw, 4rem);
      line-height: 1.1;
      max-width: 100%;
    }

    .hero-bottom {
      align-items: stretch;
    }

    .hero-sub {
      max-width: 100%;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
    }

    .hero-actions :global(.btn) {
      width: 100%;
      justify-content: center;
    }

    .hero-ghost-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
