---
// TODO: Replace 27000000000 with the real WhatsApp number before go-live
const WA_NUMBER = "27761823532";
---

<div class="inquiry-strip">
  <div class="inquiry-strip-inner wrap">
    <div class="reveal">
      <span class="inquiry-strip-label">Begin the Inquiry</span>
      <h2 class="inquiry-strip-heading">Tell us about your moment.</h2>
      <p class="inquiry-strip-sub">
        Fill in what you know and we'll be in touch to talk through the rest.
        This is the beginning of a conversation, not a booking form.
      </p>
      <a href="/contact" class="btn-ol-light">Go to Full Enquiry Form</a>
    </div>

    <form id="inquiry-form" method="POST" class="reveal d2">
      <!-- TODO: Replace YOUR_WEB3FORMS_KEY with key from web3forms.com -->
      <input
        type="hidden"
        name="access_key"
        value="a99d482b-7729-4551-8bb6-08de2e564d4a"
      />
      <input type="hidden" name="subject" value="New Enquiry — Venue Oaón" />
      <input type="checkbox" name="botcheck" style="display:none" />

      <div class="form-grid">
        <div class="fg">
          <label for="h-name">Your Name</label>
          <input
            type="text"
            id="h-name"
            name="name"
            placeholder="Jane Doe"
            autocomplete="name"
            required
          />
        </div>
        <div class="fg">
          <label for="h-email">Email Address</label>
          <input
            type="email"
            id="h-email"
            name="email"
            placeholder="info@venueoaon.co.za"
            autocomplete="email"
            required
          />
        </div>
        <div class="fg">
          <label for="h-etype">Event Type</label>
          <select id="h-etype" name="etype">
            <option value="" disabled selected>Select type</option>
            <option>Baby Shower</option>
            <option>Kitchen Tea</option>
            <option>Bridal Shower</option>
            <option>Birthday</option>
            <option>Other</option>
          </select>
        </div>
        <div class="fg">
          <label for="h-date">Preferred Date</label>
          <input type="date" id="h-date" name="date" />
        </div>
        <div class="form-submit">
          <button type="submit" class="btn-submit">Send Inquiry</button>
        </div>
      </div>
      <p class="inquiry-note">
        We aim to respond within 24 hours.
        <a
          href={`https://wa.me/${WA_NUMBER}`}
          target="_blank"
          rel="noopener noreferrer">Message on WhatsApp</a
        >.
      </p>
    </form>
    <div
      id="inquiry-success"
      class="form-feedback form-feedback--success"
      style="display:none;"
    >
      <p class="form-feedback-title">Thank you — we'll be in touch.</p>
      <p class="form-feedback-body">We aim to respond within 24 hours.</p>
    </div>
    <div
      id="inquiry-error"
      class="form-feedback form-feedback--error"
      style="display:none;"
    >
      <p class="form-feedback-body">
        Something went wrong. Please try again or message us on WhatsApp.
      </p>
    </div>
  </div>
</div>

<style>
  .inquiry-strip {
    background: #1a1a1a;
    padding: clamp(4rem, 8vw, 7rem) 0;
  }
  .inquiry-strip-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 900px) {
    .inquiry-strip-inner {
      grid-template-columns: 1fr 1.5fr;
      gap: 5rem;
      align-items: start;
    }
  }

  .inquiry-strip-label {
    font-size: var(--text-xs);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #8c8578;
    display: block;
    margin-bottom: 1rem;
  }
  .inquiry-strip-heading {
    font-family: "Tenor Sans", serif;
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 400;
    letter-spacing: 0.02em;
    line-height: 1.1;
    color: #ffffff;
    margin-bottom: 1.25rem;
    /* Subtle text shadow ensures contrast even if background lightens */
    text-shadow: 0 1px 12px rgba(0,0,0,0.18);
  }
  .inquiry-strip-sub {
    font-size: var(--text-body);
    color: #8c8578;
    line-height: 1.75;
  }

  /* Ghost button — bordered, 48px tall, meets WCAG 2.5.5 touch target */
  .btn-ol-light {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: "Tenor Sans", serif;
    font-size: var(--text-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0 32px;
    border-radius: 2px;
    border: 1px solid rgba(255, 255, 255, 0.45);
    color: white;
    margin-top: 2rem;
    min-height: 48px;
    transition: background 0.22s ease, border-color 0.22s ease;
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }
  .btn-ol-light:hover {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.75);
  }
  .btn-ol-light:focus-visible {
    outline: 2px solid rgba(255, 255, 255, 0.65);
    outline-offset: 2px;
  }

  /* Dark-mode form overrides */
  .inquiry-strip input,
  .inquiry-strip select,
  .inquiry-strip textarea {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.12);
    color: #ffffff;
  }
  .inquiry-strip input::placeholder,
  .inquiry-strip textarea::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }
  .inquiry-strip input:focus,
  .inquiry-strip select:focus,
  .inquiry-strip textarea:focus {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.4);
  }
  .inquiry-strip label {
    color: rgba(255, 255, 255, 0.4);
  }
  .inquiry-strip select {
    color: rgba(255, 255, 255, 0.7);
  }
  .inquiry-strip select option {
    background: #1a1a1a;
  }

  .btn-submit {
    font-family: "Tenor Sans", serif;
    font-size: var(--text-xs);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    padding: 0 32px;
    border-radius: 2px;
    border: none;
    background: #8b6448;
    color: #ffffff;
    min-height: 48px;
    cursor: pointer;
    transition: background 0.22s ease;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .btn-submit:hover { background: #6e4e38; }
  .btn-submit:focus-visible { outline: 2px solid #8b6448; outline-offset: 3px; }

  .inquiry-note {
    font-size: var(--text-sm);
    color: #8c8578;
    margin-top: 1.25rem;
  }
  /* Boosted from 0.45 → 0.82 for ≥4.5:1 contrast ratio on #1a1a1a bg */
  .inquiry-note a {
    color: rgba(255, 255, 255, 0.82);
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.2s;
  }
  .inquiry-note a:hover { color: #ffffff; }
  .inquiry-note a:focus-visible { outline: 2px solid rgba(255,255,255,0.6); outline-offset: 2px; border-radius: 2px; }

  .form-feedback {
    padding: 1.5rem 2rem;
    border-radius: 6px;
    margin-top: 1rem;
  }
  .form-feedback--success {
    background: #ede5dc;
  }
  .form-feedback--error {
    background: rgba(255, 255, 255, 0.08);
    border: 0.5px solid rgba(255, 255, 255, 0.2);
  }
  .form-feedback-title {
    font-family: "Tenor Sans", serif;
    font-size: 1rem;
    letter-spacing: 0.04em;
    color: #1a1a1a;
    margin-bottom: 0.375rem;
  }
  .form-feedback-body {
    font-size: var(--text-sm);
    color: #6b6560;
  }
  .form-feedback--error .form-feedback-body {
    color: rgba(255, 255, 255, 0.6);
  }
</style>

<script>
  const form = document.getElementById("inquiry-form");
  const success = document.getElementById("inquiry-success");
  const error = document.getElementById("inquiry-error");

  if (form instanceof HTMLFormElement) {
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      if (error) error.style.display = "none";
      const data = new FormData(form);
      try {
        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          body: data,
        });
        const json = await res.json();
        if (json.success) {
          form.style.display = "none";
          if (success) success.style.display = "block";
        } else {
          if (error) error.style.display = "block";
        }
      } catch {
        if (error) error.style.display = "block";
      }
    });
  }
</script>
