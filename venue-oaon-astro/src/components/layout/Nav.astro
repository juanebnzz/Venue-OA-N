---
const pathname = Astro.url.pathname;

const links = [
  { href: '/',         label: 'Home' },
  { href: '/about',    label: 'About' },
  { href: '/packages', label: 'Packages' },
  { href: '/gallery',  label: 'Gallery' },
  { href: '/contact',  label: 'Contact' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<nav class="nav" role="navigation" aria-label="Main navigation">
  <a href="/" class="nav-logo" aria-label="Venue Oaón: Home">
    <img
      src="/images/venue-oaon-logo.png"
      alt="Venue Oaón Logo"
      class="nav-logo-img"
    />
  </a>

  <ul class="nav-links" role="list">
    {links.map(({ href, label }) => (
      <li>
        <a href={href} class={isActive(href) ? 'active' : ''}>{label}</a>
      </li>
    ))}
  </ul>

  <div class="nav-right">
    <a href="/contact" class="nav-cta">Enquire</a>
    <button
      class="hamburger"
      id="hbg"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mob"
    >
      <span></span><span></span><span></span>
    </button>
  </div>
</nav>

<!-- Mobile menu : uses max-height transition, NOT display toggle -->
<nav
  class="mobile-menu"
  id="mob"
  aria-label="Mobile navigation"
  style="max-height:0;overflow:hidden;transition:max-height 0.35s ease;"
>
  {links.map(({ href, label }) => (
    <a href={href} class={isActive(href) ? 'active' : ''}>{label}</a>
  ))}
  <a href="/contact" class="mobile-cta">Begin the Inquiry →</a>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    height: var(--nav-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--g);
    background: rgba(255,255,255,0.96);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 0.5px solid #E0DDD8;
    transition: box-shadow 0.3s ease;
  }
  .nav.scrolled { box-shadow: 0 2px 24px rgba(0,0,0,0.06); }
  
  .nav-logo-img {
    height: 80px;
    width: auto;
    object-fit: contain;
    transition: height 0.3s ease;
  }
  @media (max-width: 768px) {
    .nav-logo-img {
      height: 60px;
    }
  }
  @media (max-width: 480px) {
    .nav-logo-img {
      height: 46px;
    }
  }

  .nav-links {
    display: none;
    list-style: none;
    gap: 2.5rem;
    align-items: center;
  }
  @media (min-width: 900px) { .nav-links { display: flex; } }

  .nav-links a {
    font-size: var(--text-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #8C8578;
    position: relative;
    padding-bottom: 2px;
    transition: color 0.2s ease;
  }
  .nav-links a::after {
    content: '';
    position: absolute;
    bottom: -2px; left: 0; right: 0;
    height: 0.5px;
    background: #1A1A1A;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }
  .nav-links a:hover,
  .nav-links a.active { color: #1A1A1A; }
  .nav-links a:hover::after,
  .nav-links a.active::after { transform: scaleX(1); }

  .nav-right { display: flex; align-items: center; gap: 1.25rem; }

  .nav-cta {
    font-family: 'Tenor Sans', serif;
    font-size: var(--text-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0 22px;
    border-radius: 2px;
    background: #8B6448;
    color: #FFFFFF;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
    transition: background 0.2s;
    text-decoration: none;
  }
  .nav-cta:hover { background: #1A1A1A; }
  .nav-cta:focus-visible { outline: 2px solid #8B6448; outline-offset: 3px; }

  .hamburger {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    min-height: 44px;
    min-width: 44px;
    align-items: center;
    justify-content: center;
  }
  .hamburger:focus-visible { outline: 2px solid #8B6448; outline-offset: 2px; border-radius: 2px; }
  @media (min-width: 900px) { .hamburger { display: none; } }

  .hamburger span {
    display: block;
    width: 20px;
    height: 0.5px;
    background: #1A1A1A;
    transition: all 0.3s ease;
    transform-origin: center;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(5.5px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-5.5px) rotate(-45deg); }

  .mobile-menu {
    position: fixed;
    top: var(--nav-h);
    left: 0; right: 0;
    z-index: 199;
    background: #FFFFFF;
    border-bottom: 0.5px solid #E0DDD8;
    display: flex;
    flex-direction: column;
  }
  .mobile-menu a {
    padding: 1.125rem var(--g);
    font-size: var(--text-xs);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #8C8578;
    border-bottom: 0.5px solid #E0DDD8;
    /* 52px height already satisfies WCAG 2.5.5 44px touch target */
    min-height: 52px;
    display: flex;
    align-items: center;
    transition: color 0.2s, background 0.2s;
  }
  .mobile-menu a:hover, .mobile-menu a.active { color: #1A1A1A; background: #F5F2EE; }
  .mobile-menu a:focus-visible { outline: 2px solid #8B6448; outline-offset: -4px; }
  .mobile-menu .mobile-cta { color: #8B6448; font-family: 'Tenor Sans', serif; }
</style>

<script>
  const hbg = document.getElementById('hbg') as HTMLButtonElement | null;
  const mob = document.getElementById('mob') as HTMLElement | null;
  if (hbg && mob) {
    hbg.addEventListener('click', () => {
      const open = hbg.getAttribute('aria-expanded') === 'true';
      const next = !open;
      hbg.setAttribute('aria-expanded', String(next));
      hbg.classList.toggle('open', next);
      mob.style.maxHeight = next ? mob.scrollHeight + 'px' : '0';
    });
    mob.querySelectorAll('a').forEach(a => {
      a.addEventListener('click', () => {
        hbg?.setAttribute('aria-expanded', 'false');
        hbg?.classList.remove('open');
        mob.style.maxHeight = '0';
      });
    });
  }
</script>
