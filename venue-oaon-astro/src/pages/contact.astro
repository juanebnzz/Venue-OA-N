---
import BaseLayout from '../components/layout/BaseLayout.astro';
import PageHero from '../components/sections/PageHero.astro';

// TODO: Replace 27000000000 with the real WhatsApp number before go-live
const WA_NUMBER = '27000000000';
const WA_MSG    = encodeURIComponent("Hi, I'd like to enquire about Venue Oaón");
---

<BaseLayout
  title="Contact — Venue Oaón"
  description="Enquire about Venue Oaón in Montana, Pretoria. Book a site visit or begin planning your event."
>
  <PageHero
    eyebrow="Begin the Inquiry"
    title="Tell us about<br />your moment."
  />

  <section class="section">
    <div class="wrap">
      <div class="contact-grid">

        <!-- Aside -->
        <div class="contact-aside reveal">
          <div class="aside-block">
            <span class="aside-block-title">Get in touch</span>

            <div class="contact-detail">
              <svg class="contact-detail-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M10 2C6.686 2 4 4.686 4 8c0 4 6 10 6 10s6-6 6-10c0-3.314-2.686-6-6-6zm0 8a2 2 0 110-4 2 2 0 010 4z" stroke="currentColor" stroke-width="0.75"/></svg>
              <div class="contact-detail-body">
                <span class="contact-detail-label">Address</span>
                <span class="contact-detail-val">Montana, Pretoria<br />Gauteng, South Africa</span>
              </div>
            </div>

            <div class="contact-detail">
              <svg class="contact-detail-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true"><path d="M2 5a2 2 0 012-2h12a2 2 0 012 2v10a2 2 0 01-2 2H4a2 2 0 01-2-2V5z" stroke="currentColor" stroke-width="0.75"/><path d="M2 5l8 6 8-6" stroke="currentColor" stroke-width="0.75"/></svg>
              <div class="contact-detail-body">
                <span class="contact-detail-label">Email</span>
                <span class="contact-detail-val"><a href="mailto:hello@venueoaon.co.za">hello@venueoaon.co.za</a></span>
              </div>
            </div>

            <div class="contact-detail">
              <svg class="contact-detail-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true"><circle cx="10" cy="10" r="8" stroke="currentColor" stroke-width="0.75"/><path d="M10 6v4l2.5 2.5" stroke="currentColor" stroke-width="0.75" stroke-linecap="round"/></svg>
              <div class="contact-detail-body">
                <span class="contact-detail-label">Response time</span>
                <span class="contact-detail-val">Within 24 hours</span>
              </div>
            </div>

            <div class="contact-detail">
              <svg class="contact-detail-icon" viewBox="0 0 20 20" fill="none" aria-hidden="true"><rect x="2" y="4" width="16" height="13" rx="1.5" stroke="currentColor" stroke-width="0.75"/><path d="M2 8h16" stroke="currentColor" stroke-width="0.75"/><path d="M6 2v3M14 2v3" stroke="currentColor" stroke-width="0.75" stroke-linecap="round"/></svg>
              <div class="contact-detail-body">
                <span class="contact-detail-label">Time slots</span>
                <span class="contact-detail-val">08:00–13:00 · 14:00–19:00</span>
              </div>
            </div>

            <div style="margin-top:1rem;">
              <a
                href={`https://wa.me/${WA_NUMBER}?text=${WA_MSG}`}
                class="wa-option"
                target="_blank"
                rel="noopener noreferrer"
              >
                <div class="wa-option-icon">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="white" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg>
                </div>
                <div class="wa-option-text">
                  <span class="wa-option-title">Chat on WhatsApp</span>
                  <span class="wa-option-sub">Often the quickest way to reach us</span>
                </div>
              </a>
            </div>
          </div>

          <!-- Suites -->
          <div class="aside-block">
            <span class="aside-block-title">Available Suites</span>
            <div class="suite-cards">
              {[
                { name:'Myrrh Suite',  meta:'Indoor · 30–40' },
                { name:'Olive Suite',  meta:'In/Out · 20–30' },
                { name:'Garden Suite', meta:'Outdoor · 30–40' },
              ].map(({ name, meta }) => (
                <div class="suite-card-sm">
                  <span class="suite-card-sm-name">{name}</span>
                  <span class="suite-card-sm-meta">{meta}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Map placeholder -->
          <div class="aside-block">
            <span class="aside-block-title">Location</span>
            <div class="map-ph" aria-label="Map placeholder — replace with Google Maps embed">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="0.75" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
              <span>Montana, Pretoria</span>
              <span style="opacity:0.6;font-size:0.5rem;">Add Google Maps embed here</span>
            </div>
          </div>
        </div>

        <!-- Form -->
        <div class="form-card reveal d2">
          <h2 class="form-card-title">Begin the Inquiry</h2>
          <p class="form-card-sub">Fill in what you know — we'll follow up within 24 hours to talk through the rest. No commitment, just a conversation.</p>
          <form
            name="contact"
            method="POST"
            data-netlify="true"
            netlify-honeypot="bot-field"
            novalidate
          >
            <input type="hidden" name="form-name" value="contact" />
            <p style="display:none;"><label>Don't fill this out: <input name="bot-field" /></label></p>

            <div class="form-grid">
              <div class="fg"><label for="c-name">Your Name</label><input type="text" id="c-name" name="name" placeholder="Jane Doe" autocomplete="name" required /></div>
              <div class="fg"><label for="c-email">Email Address</label><input type="email" id="c-email" name="email" placeholder="jane@email.com" autocomplete="email" required /></div>
              <div class="fg"><label for="c-phone">Contact Number</label><input type="tel" id="c-phone" name="phone" placeholder="+27 82 000 0000" autocomplete="tel" /></div>
              <div class="fg">
                <label for="c-etype">Type of Event</label>
                <select id="c-etype" name="etype" required>
                  <option value="" disabled selected>Select event type</option>
                  <option>Baby Shower</option><option>Kitchen Tea</option>
                  <option>Bridal Shower</option><option>Birthday</option><option>Other</option>
                </select>
              </div>
              <div class="fg">
                <label for="c-suite">Suite Preference</label>
                <select id="c-suite" name="suite">
                  <option value="" disabled selected>Which suite?</option>
                  <option>Myrrh Suite (Indoor, 30–40 pax)</option>
                  <option>Olive Suite (In/Out, 20–30 pax)</option>
                  <option>Garden Suite (Outdoor, 30–40 pax)</option>
                  <option>Not sure yet</option>
                </select>
              </div>
              <div class="fg"><label for="c-date">Preferred Date</label><input type="date" id="c-date" name="date" /></div>
              <div class="fg"><label for="c-guests">Estimated Guest Count</label><input type="number" id="c-guests" name="guests" placeholder="e.g. 25" min="1" max="40" /></div>
              <div class="fg">
                <label for="c-pkg">Package Interest</label>
                <select id="c-pkg" name="pkg">
                  <option value="" disabled selected>Which package?</option>
                  <option>Essential</option><option>Signature</option>
                  <option>Premier</option><option>Grand</option>
                  <option>Suite hire only</option><option>Not sure yet</option>
                </select>
              </div>
              <div class="fg fg--full">
                <label for="c-msg">Tell us about your event</label>
                <textarea id="c-msg" name="msg" placeholder="What are you celebrating? Any décor ideas, special requests, or things we should know?"></textarea>
              </div>
              <div class="form-submit">
                <button type="submit" class="btn-submit">Send My Inquiry</button>
              </div>
            </div>
            <p class="form-note">We aim to respond within 24 hours. Or <a href={`https://wa.me/${WA_NUMBER}`} target="_blank" rel="noopener noreferrer">message us on WhatsApp</a> for a faster response.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--linen">
    <div class="wrap">
      <div class="section-header reveal" style="max-width:680px;">
        <span class="label">FAQ</span>
        <h2 class="section-title" style="margin-top:1rem;">Questions we hear often.</h2>
      </div>
      <div class="faq" style="max-width:680px;" role="list">
        {[
          { q:'Do you charge corkage?',               a:'Never. Bring your own wine, champagne, spirits, or soft drinks. No corkage fees, no hidden charges. Stock up and celebrate exactly as you\'d like.' },
          { q:'Can I bring my own caterer?',           a:'Absolutely. Venue Oaón is fully self-catering. Bring your own food, order from your favourite restaurant, or hire a caterer. Kitchen access is available on selected packages.' },
          { q:'How do I get pricing?',                 a:'We don\'t publish pricing because every event is different — guest count, suite, package, and add-ons all affect the final quote. Fill in the form above and we\'ll come back to you with a full breakdown.' },
          { q:'Can I book more than one suite?',       a:'Yes — you can book multiple suites for the same time slot if your event needs more space. We\'ll discuss what makes sense when you enquire.' },
          { q:'What time slots are available?',        a:'We run two time slots per day — morning (08:00–13:00) and afternoon (14:00–19:00). Each slot gives you a freshly prepared space. We don\'t run back-to-back events in the same suite.' },
          { q:'Is there parking?',                     a:'Yes — on-site secured parking for all guests. No street parking stress on the day of your event.' },
          { q:'Do I need to use Oaón Events for décor?', a:'No. You\'re welcome to bring your own décor team. However, all our packages are offered through Oaón Events and we recommend them highly — they know the space well and the coordination is seamless.' },
        ].map(({ q, a }) => (
          <details class="faq-item reveal">
            <summary class="faq-q">
              {q}
              <span class="faq-icon" aria-hidden="true">+</span>
            </summary>
            <p class="faq-a">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .contact-grid { display: grid; gap: clamp(4rem,8vw,7rem); grid-template-columns: 1fr; }
  @media (min-width: 900px) { .contact-grid { grid-template-columns: 1fr 1.5fr; align-items: start; } }

  .contact-aside { display: flex; flex-direction: column; gap: 2.5rem; }
  .aside-block { display: flex; flex-direction: column; gap: 0; }
  .aside-block-title { font-size: var(--text-xs); letter-spacing: 0.2em; text-transform: uppercase; color: #8C8578; display: block; margin-bottom: 1.25rem; }

  .contact-detail { padding: 1.125rem 0; border-bottom: 0.5px solid #E0DDD8; display: flex; gap: 1.25rem; align-items: flex-start; }
  .contact-detail:first-of-type { border-top: 0.5px solid #E0DDD8; }
  .contact-detail-icon  { color: #8B6448; width: 18px; height: 18px; flex-shrink: 0; margin-top: 2px; }
  .contact-detail-body  { display: flex; flex-direction: column; gap: 2px; }
  .contact-detail-label { font-size: var(--text-xs); letter-spacing: 0.14em; text-transform: uppercase; color: #8C8578; }
  .contact-detail-val   { font-size: var(--text-sm); color: #1A1A1A; line-height: 1.5; }
  .contact-detail-val a { text-decoration: underline; text-underline-offset: 3px; transition: color 0.2s; }
  .contact-detail-val a:hover { color: #8B6448; }

  .wa-option { background: #F0FBF4; border: 0.5px solid #C3EACC; border-radius: 8px; padding: 1.5rem; display: flex; align-items: center; gap: 1.25rem; text-decoration: none; transition: background 0.2s; }
  .wa-option:hover { background: #E5F7EB; }
  .wa-option-icon  { background: #25D366; width: 44px; height: 44px; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .wa-option-text  { display: flex; flex-direction: column; gap: 3px; }
  .wa-option-title { font-family: 'Tenor Sans', serif; font-size: 0.9375rem; letter-spacing: 0.03em; color: #1A1A1A; }
  .wa-option-sub   { font-size: var(--text-xs); letter-spacing: 0.12em; text-transform: uppercase; color: #8C8578; }

  .suite-cards     { display: flex; flex-direction: column; gap: 0.625rem; }
  .suite-card-sm   { border: 0.5px solid #E0DDD8; border-radius: 6px; padding: 1rem 1.25rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; transition: border-color 0.2s, background 0.2s; }
  .suite-card-sm:hover { border-color: #8C8578; background: #F5F2EE; }
  .suite-card-sm-name { font-family: 'Tenor Sans', serif; font-size: 0.9375rem; letter-spacing: 0.04em; }
  .suite-card-sm-meta { font-size: var(--text-xs); letter-spacing: 0.12em; text-transform: uppercase; color: #8C8578; text-align: right; }

  .map-ph { background: linear-gradient(135deg,#EAE3DA,#D5CCBF); border-radius: 8px; height: 220px; display: flex; align-items: center; justify-content: center; flex-direction: column; gap: 0.75rem; color: #8C8578; font-size: var(--text-xs); letter-spacing: 0.14em; text-transform: uppercase; border: 0.5px solid #E0DDD8; margin-top: 1rem; }

  .form-card { background: #F5F2EE; border-radius: 12px; padding: clamp(2rem,5vw,3.5rem); }
  .form-card-title { font-family: 'Tenor Sans', serif; font-size: clamp(1.375rem,3vw,2rem); font-weight: 400; letter-spacing: 0.02em; color: #1A1A1A; margin-bottom: 0.75rem; }
  .form-card-sub   { font-size: var(--text-sm); color: #8C8578; line-height: 1.7; margin-bottom: 2rem; }

  .btn-submit {
    font-family: 'Tenor Sans', serif; font-size: var(--text-xs); letter-spacing: 0.18em;
    text-transform: uppercase; padding: 14px 32px; border-radius: 2px; border: none;
    background: #8B6448; color: #FFFFFF; min-height: 48px; cursor: pointer; transition: background 0.22s ease;
  }
  .btn-submit:hover { background: #6E4E38; }

  .faq       { display: flex; flex-direction: column; gap: 0; }
  .faq-item  { border-bottom: 0.5px solid #E0DDD8; }
  .faq-item:first-child { border-top: 0.5px solid #E0DDD8; }
  .faq-q {
    padding: 1.25rem 0; font-family: 'Tenor Sans', serif; font-size: 1rem; letter-spacing: 0.03em;
    cursor: pointer; display: flex; justify-content: space-between; align-items: center;
    gap: 1rem; list-style: none; user-select: none;
  }
  .faq-q::-webkit-details-marker { display: none; }
  .faq-icon { flex-shrink: 0; width: 20px; height: 20px; display: flex; align-items: center; justify-content: center; color: #8C8578; transition: transform 0.3s; }
  details[open] .faq-icon { transform: rotate(45deg); }
  .faq-a { padding: 0 0 1.25rem; font-size: var(--text-sm); color: #8C8578; line-height: 1.7; }

  .section-title { font-family: 'Tenor Sans', serif; font-size: var(--text-h2); font-weight: 400; letter-spacing: 0.02em; line-height: 1.1; color: #1A1A1A; }
</style>
